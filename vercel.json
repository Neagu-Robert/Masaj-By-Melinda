{
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=4096"
    }
  },
  "routes": [
    {
      "src": "/reset-password",
      "dest": "/index.html"
    },
    {
      "src": "/admin(.*)",
      "dest": "/index.html"
    },
    {
      "src": "/profile",
      "dest": "/index.html"
    },
    {
      "src": "/home",
      "dest": "/index.html"
    },
    {
      "src": "/book",
      "dest": "/index.html"
    },
    {
      "src": "/pachete",
      "dest": "/index.html"
    },
    {
      "src": "/forgot-password",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
} 