{
  "outputDirectory": "build/client",
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=4096"
    }
  },
  "routes": [
    {
      "src": "/home",
      "status": 301,
      "headers": { "Location": "/" }
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|webp))",
      "dest": "/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/book$",
      "dest": "/book/index.html"
    },
    {
      "src": "^/pachete$",
      "dest": "/pachete/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/__spa-fallback.html"
    }
  ]
}